# ──────────────────────────────────────────────────────────────
# BFM – Buy For Me | Environment Variables
# ──────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Service role key — required for search_cache writes from Node backend
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Node Crawlee API ─────────────────────────────────────────
PORT=3001
FALLBACK_THB_TO_MMK=115

# Messenger page for "Buy for me" — your direct Messenger link
# VITE_MESSENGER_PAGE_URL=https://m.me/yourpage
# Optional Facebook page URL fallback (if messenger target is unavailable)
# VITE_FACEBOOK_PAGE_URL=https://www.facebook.com/yourpage

# Optional: paste Cookie header from lazada.co.th DevTools if Lazada price/title fetch fails
# LAZADA_COOKIE=

# Optional: scraping proxy for production hosts (Render etc.) where Lazada
# blocks datacenter IPs. Use {url} as placeholder for the encoded target URL.
# Example (ScraperAPI): LAZADA_PROXY_URL=https://api.scraperapi.com/?api_key=YOUR_KEY&country_code=th&render=false&url={url}
# LAZADA_PROXY_URL=

# RapidAPI Lazada search (preferred — much faster than scraping)
# Subscribe to: https://rapidapi.com/tmapi-tmapi-default/api/lazada-api
# RAPIDAPI_KEY=your_rapidapi_key
# RAPIDAPI_LAZADA_HOST=lazada-api.p.rapidapi.com

# Optional RapidAPI Shopee product preview (falls back to RAPIDAPI_KEY)
# RAPIDAPI_SHOPEE_KEY=
# RAPIDAPI_SHOPEE_HOST=shopee-api2.p.rapidapi.com

# ── Google AdSense (enable after site approval) ───────────────
# Responsive display ad shown with Lazada search results
# VITE_ADSENSE_CLIENT_ID=ca-pub-1234567890123456
# VITE_ADSENSE_SEARCH_SLOT=1234567890

# VITE_API_URL=https://api.yourdomain.com
